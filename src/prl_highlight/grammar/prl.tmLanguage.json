{
  "scopeName": "source.prl",
  "name": "PRL",
  "fileTypes": ["prl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#tag" },
    { "include": "#import-line" },
    { "include": "#toplevel-keywords" },
    { "include": "#declare-block" },
    { "include": "#rule-block" },
    { "include": "#fallback" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "//[^\\n]*", "name": "comment.line.double-slash.prl" },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.prl"
        }
      ]
    },
    "operators": {
      "match": "==|!=|<=|>=|<|>|=",
      "name": "keyword.operator.comparison.prl"
    },
    "tag": {
      "match": "@([A-Za-z_][\\w-]*)(?:\\(([^)]*)\\))?",
      "captures": {
        "1": { "name": "entity.name.tag.prl" },
        "2": { "name": "meta.tag-value.prl" }
      }
    },
    "toplevel-keywords": {
      "match": "\\b(?:package|from|as|when|not|or|exists|forall|accumulate|salience|no-loop)\\b",
      "name": "keyword.control.prl"
    },
    "import-line": {
      "begin": "\\b(import)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.prl" } },
      "end": "$",
      "patterns": [
        { "include": "#toplevel-keywords" },
        { "match": "[A-Za-z_]\\w*", "name": "entity.name.type.prl" },
        { "include": "#fallback" }
      ]
    },
    "declare-block": {
      "begin": "\\b(declare)\\s+([A-Za-z_]\\w*)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.prl" },
        "2": { "name": "entity.name.type.prl" }
      },
      "end": "\\b(end)\\b",
      "endCaptures": { "1": { "name": "keyword.control.prl" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#tag" },
        {
          "match": "\\b(extends)\\s+([A-Za-z_]\\w*)\\b",
          "captures": {
            "1": { "name": "keyword.control.prl" },
            "2": { "name": "entity.name.type.prl" }
          }
        },
        { "include": "#field-decl" },
        { "include": "#fallback" }
      ]
    },
    "field-decl": {
      "begin": "([A-Za-z_]\\w*)\\s*(:)(?!:)",
      "beginCaptures": {
        "1": { "name": "variable.other.property.prl" },
        "2": { "name": "punctuation.separator.binding.prl" }
      },
      "end": "$",
      "patterns": [
        { "include": "#comments" },
        {
          "begin": "(?=[A-Za-z_])",
          "end": "(?==)|$",
          "patterns": [{ "include": "#type-ref" }, { "include": "#fallback" }]
        },
        {
          "begin": "=",
          "beginCaptures": { "0": { "name": "keyword.operator.comparison.prl" } },
          "end": "$",
          "patterns": [
            { "include": "#comments" },
            { "include": "#container-literal" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        }
      ]
    },
    "type-ref": {
      "patterns": [
        {
          "match": "([A-Za-z_]\\w*)\\s*(?=\\[)",
          "captures": { "1": { "name": "entity.name.type.prl" } }
        },
        { "include": "#generic-brackets-1" },
        { "match": "[A-Za-z_]\\w*", "name": "entity.name.type.prl" }
      ]
    },
    "generic-brackets-1": { "$comment": "ponytail: 3-deep named chain (not true self-recursion) works around a textmate-grammar-python bug where a rule directly/indirectly including itself loses its own closing bracket on the 2nd+ nesting level - see declare-field-defaults story notes. 3 levels covers pRETE's real usage (max 2, per its own test suite) with headroom; a 4th level degrades gracefully to plain/fallback scope rather than crashing.", "begin": "\\[", "beginCaptures": { "0": { "name": "punctuation.section.generic.prl" } }, "end": "\\]", "endCaptures": { "0": { "name": "punctuation.section.generic.prl" } }, "patterns": [
        { "match": ",", "name": "punctuation.separator.generic.prl" },
        {
          "match": "([A-Za-z_]\\w*)\\s*(?=\\[)",
          "captures": { "1": { "name": "entity.name.type.prl" } }
        },
        { "include": "#generic-brackets-2" },
        { "match": "[A-Za-z_]\\w*", "name": "entity.name.type.prl" }
      ] },
    "generic-brackets-2": { "begin": "\\[", "beginCaptures": { "0": { "name": "punctuation.section.generic.prl" } }, "end": "\\]", "endCaptures": { "0": { "name": "punctuation.section.generic.prl" } }, "patterns": [
        { "match": ",", "name": "punctuation.separator.generic.prl" },
        {
          "match": "([A-Za-z_]\\w*)\\s*(?=\\[)",
          "captures": { "1": { "name": "entity.name.type.prl" } }
        },
        { "include": "#generic-brackets-3" },
        { "match": "[A-Za-z_]\\w*", "name": "entity.name.type.prl" }
      ] },
    "generic-brackets-3": { "begin": "\\[", "beginCaptures": { "0": { "name": "punctuation.section.generic.prl" } }, "end": "\\]", "endCaptures": { "0": { "name": "punctuation.section.generic.prl" } }, "patterns": [
        { "match": ",", "name": "punctuation.separator.generic.prl" },
        { "match": "[A-Za-z_]\\w*", "name": "entity.name.type.prl" },
        { "include": "#fallback" }
      ] },
    "container-literal": {
      "patterns": [
        { "include": "#container-literal-1" }
      ]
    },
    "container-literal-1": {
      "$comment": "ponytail: same 3-deep named-chain workaround as generic-brackets-*, for list/dict default-value literals.",
      "patterns": [
        {
          "begin": "\\[",
          "beginCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "end": "\\]",
          "endCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "patterns": [
            { "match": ",", "name": "punctuation.separator.container.prl" },
            { "include": "#comments" },
            { "include": "#container-literal-2" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        },
        {
          "begin": "\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "patterns": [
            { "match": "[,:]", "name": "punctuation.separator.container.prl" },
            { "include": "#comments" },
            { "include": "#container-literal-2" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        }
      ]
    },
    "container-literal-2": {
      "patterns": [
        {
          "begin": "\\[",
          "beginCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "end": "\\]",
          "endCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "patterns": [
            { "match": ",", "name": "punctuation.separator.container.prl" },
            { "include": "#comments" },
            { "include": "#container-literal-3" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        },
        {
          "begin": "\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "patterns": [
            { "match": "[,:]", "name": "punctuation.separator.container.prl" },
            { "include": "#comments" },
            { "include": "#container-literal-3" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        }
      ]
    },
    "container-literal-3": {
      "patterns": [
        {
          "begin": "\\[",
          "beginCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "end": "\\]",
          "endCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "patterns": [
            { "match": ",", "name": "punctuation.separator.container.prl" },
            { "include": "#comments" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        },
        {
          "begin": "\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.container.prl" } },
          "patterns": [
            { "match": "[,:]", "name": "punctuation.separator.container.prl" },
            { "include": "#comments" },
            { "include": "#literals" },
            { "include": "#fallback" }
          ]
        }
      ]
    },
    "rule-block": {
      "begin": "\\b(rule)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.prl" } },
      "end": "\\b(end)\\b",
      "endCaptures": { "1": { "name": "keyword.control.prl" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#tag" },
        { "include": "#toplevel-keywords" },
        { "include": "#then-block" },
        { "include": "#fact-binding" },
        { "include": "#variable-ref" },
        { "include": "#oopath-pattern" },
        { "include": "#traditional-pattern" },
        { "include": "#literals" },
        { "include": "#field-path-segment" },
        { "include": "#operators" },
        { "include": "#fallback" }
      ]
    },
    "fact-binding": {
      "match": "(?:(\\$[A-Za-z_]\\w*)|([A-Za-z_]\\w*))\\s*(:)(?!:)",
      "captures": {
        "1": { "name": "variable.other.prl" },
        "3": { "name": "punctuation.separator.binding.prl" }
      }
    },
    "traditional-pattern": {
      "begin": "([A-Za-z_]\\w*)\\s*(\\()",
      "beginCaptures": {
        "1": { "name": "entity.name.type.prl" },
        "2": { "name": "punctuation.section.pattern.prl" }
      },
      "end": "(\\))",
      "endCaptures": { "1": { "name": "punctuation.section.pattern.prl" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#literals" },
        { "include": "#variable-ref" },
        { "include": "#binding-colon" },
        { "include": "#accessor-dot" },
        { "include": "#field-path-segment" },
        { "include": "#operators" },
        { "include": "#fallback" }
      ]
    },
    "oopath-pattern": {
      "begin": "(/)([A-Za-z_]\\w*)\\s*(\\[)",
      "beginCaptures": {
        "1": { "name": "punctuation.section.pattern.prl" },
        "2": { "name": "entity.name.type.prl" },
        "3": { "name": "punctuation.section.pattern.prl" }
      },
      "end": "(\\])",
      "endCaptures": { "1": { "name": "punctuation.section.pattern.prl" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#literals" },
        { "include": "#variable-ref" },
        { "include": "#binding-colon" },
        { "include": "#accessor-dot" },
        { "include": "#field-path-segment" },
        { "include": "#operators" },
        { "include": "#fallback" }
      ]
    },
    "field-path-segment": {
      "match": "[A-Za-z_]\\w*",
      "name": "variable.other.property.prl"
    },
    "accessor-dot": {
      "match": "\\.",
      "name": "punctuation.accessor.prl"
    },
    "variable-ref": {
      "match": "\\$[A-Za-z_]\\w*",
      "name": "variable.other.prl"
    },
    "binding-colon": {
      "match": ":",
      "name": "punctuation.separator.binding.prl"
    },
    "literals": {
      "patterns": [
        {
          "match": "\"(?:[^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.double.prl"
        },
        {
          "match": "'(?:[^'\\\\]|\\\\.)*'",
          "name": "string.quoted.single.prl"
        },
        { "match": "-?\\d+\\.\\d+", "name": "constant.numeric.prl" },
        { "match": "-?\\d+", "name": "constant.numeric.prl" },
        {
          "match": "\\b(?:true|false|True|False)\\b",
          "name": "constant.language.boolean.prl"
        },
        {
          "match": "\\b(?:null|None)\\b",
          "name": "constant.language.null.prl"
        }
      ]
    },
    "then-block": {
      "begin": "\\b(then)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.prl" } },
      "end": "(?=\\bend\\b)",
      "name": "meta.embedded.block.python.prl",
      "patterns": [{ "include": "source.python" }, { "include": "#fallback" }]
    },
    "fallback": {
      "match": "[^\\s]+",
      "name": "source.prl"
    }
  }
}
